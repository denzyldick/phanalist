#!/usr/bin/env php
<?php

function get_project_version() {
    $cargoPath = __DIR__ . '/Cargo.toml';
    if (file_exists($cargoPath)) {
        $content = file_get_contents($cargoPath);
        if (preg_match('/^version = "([^"]+)"/m', $content, $matches)) {
            return $matches[1];
        }
    }
    return 'latest'; // Fallback
}

$version = get_project_version();
$binDir = __DIR__ . '/bin';
$executableName = (strtoupper(substr(PHP_OS, 0, 3)) === 'WIN') ? 'phanalist.exe' : 'phanalist';

// 1. Detect Architecture and OS
function get_target() {
    $os = PHP_OS;
    $arch = php_uname('m');

    if (strpos(strtoupper($os), 'WIN') !== false) {
        return 'x86_64-pc-windows-msvc';
    }

    if (strpos(strtoupper($os), 'DARWIN') !== false) {
        if ($arch === 'arm64' || $arch === 'aarch64') {
            return 'aarch64-apple-darwin';
        }
        return 'x86_64-apple-darwin';
    }

    if (strpos(strtoupper($os), 'LINUX') !== false) {
        $isMusl = strpos(shell_exec('ldd --version 2>&1') ?? '', 'musl') !== false;
        $libc = $isMusl ? 'musl' : 'gnu';

        if ($arch === 'arm64' || $arch === 'aarch64') {
            return "aarch64-unknown-linux-$libc";
        }
        return "x86_64-unknown-linux-$libc";
    }

    return null;
}

$target = get_target();
if (!$target) {
    echo "Unsupported OS/Architecture: " . PHP_OS . " (" . php_uname('m') . ")" . PHP_EOL;
    exit(1);
}

$binPath = "$binDir/$target/$executableName";

// 2. Auto-download if missing
if (!file_exists($binPath)) {
    if (!is_dir(dirname($binPath))) {
        mkdir(dirname($binPath), 0755, true);
    }

    echo "Phanalist binary not found for $target. Downloading..." . PHP_EOL;
    
    $extension = (strpos($target, 'windows') !== false) ? 'zip' : 'tar.gz';
    $url = "https://github.com/denzyldick/phanalist/releases/latest/download/phanalist-$target.$extension";
    $tempFile = sys_get_temp_dir() . "/phanalist-$target.$extension";

    if (!copy($url, $tempFile)) {
        echo "Failed to download binary from $url" . PHP_EOL;
        exit(1);
    }

    if ($extension === 'zip') {
        $zip = new ZipArchive;
        if ($zip->open($tempFile) === TRUE) {
            $zip->extractTo(dirname($binPath));
            $zip->close();
        } else {
            echo "Failed to extract ZIP file." . PHP_EOL;
            exit(1);
        }
    } else {
        exec("tar -xzf " . escapeshellarg($tempFile) . " -C " . escapeshellarg(dirname($binPath)));
        // The tarball might contain a subfolder phanalist-$target/
        if (file_exists(dirname($binPath) . "/phanalist-$target/phanalist")) {
            rename(dirname($binPath) . "/phanalist-$target/phanalist", $binPath);
        }
    }

    unlink($tempFile);
    chmod($binPath, 0755);
}

// 3. Execute the binary
array_shift($argv); // Remove script name
$args = array_map('escapeshellarg', $argv);
$command = escapeshellarg($binPath) . ' ' . implode(' ', $args);

passthru($command, $exitCode);
exit($exitCode);
